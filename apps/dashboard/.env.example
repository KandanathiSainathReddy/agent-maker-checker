# Local dev only (read via import.meta.env.VITE_PROXY_URL — see src/api.js).
# Vite only exposes env vars prefixed VITE_ to client code.
#
# Copy to .env.local (git-ignored) and point at a proxy you're running
# outside docker-compose, e.g. `uvicorn app:app` on the host:
#   VITE_PROXY_URL=http://localhost:8000
#
# Precedence when the dashboard decides LIVE vs SIMULATED (src/api.js):
#   1. amplify_outputs.json -> custom.proxyUrl   (Amplify Hosting deploy)
#   2. window.__PROXY_URL__                       (docker-compose PROXY_URL, injected at
#                                                    container start — see Dockerfile)
#   3. VITE_PROXY_URL                             (this file / `vite dev`)
#   4. none -> SIMULATED mode
VITE_PROXY_URL=

# Nova playground only (read via import.meta.env.VITE_AGENT_URL — see src/api.js).
# Base URL of the separate agent-chat service (POST /agent/chat, GET
# /agent/samples, GET /agent/healthz) — not the proxy. Point at an agent
# service you're running locally, e.g.:
#   VITE_AGENT_URL=http://localhost:8100
#
# Precedence when the playground resolves the agent endpoint (src/api.js):
#   1. amplify_outputs.json -> custom.agentUrl   (Amplify Hosting deploy)
#   2. window.__AGENT_URL__                       (runtime injection seam, same
#                                                    pattern as window.__PROXY_URL__)
#   3. VITE_AGENT_URL                             (this file / `vite dev`)
#   4. none -> playground shows "agent endpoint not configured"
VITE_AGENT_URL=
