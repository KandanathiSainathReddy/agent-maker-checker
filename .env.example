# Razorpay test-mode credentials (never commit real values; test keys only)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# live   = front the real Razorpay MCP server (test mode)
# cached = replay recorded responses; full demo works offline
DEMO_MODE=cached

# State + audit persistence.
#   memory / jsonl   = local single-process default (bulletproof, no AWS)
#   dynamodb         = cloud (ephemeral, concurrent Lambdas → shared + atomic)
STATE_BACKEND=memory
AUDIT_BACKEND=jsonl
AUDIT_LOG_PATH=./data/audit.jsonl

# DynamoDB (cloud, or DynamoDB Local for the concurrency test)
DDB_ENDPOINT_URL=            # empty = real AWS; http://localhost:8001 = DynamoDB Local
DDB_STATE_TABLE=amc-state
DDB_AUDIT_TABLE=amc-audit
DDB_APPROVALS_TABLE=amc-approvals

# Bedrock (demo agent) — cost-right-sized: Nova Pro for tool use, Nova Lite for classification
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=amazon.nova-pro-v1:0
BEDROCK_LITE_MODEL_ID=amazon.nova-lite-v1:0

# Proxy
PROXY_PORT=8000
POLICY_DIR=./policies
