{
  "name": "agent-maker-checker",
  "version": "0.1.0",
  "private": true,
  "description": "Maker-checker for AI agents — enforcement proxy between an AI agent and Razorpay test rails",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:dashboard": "npm --workspace apps/dashboard run dev",
    "build:dashboard": "npm --workspace apps/dashboard run build",
    "ampx:sandbox": "ampx sandbox",
    "ampx:deploy": "ampx pipeline-deploy",
    "typecheck": "tsc -p amplify/tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@aws-amplify/backend": "^1.23.0",
    "@aws-amplify/backend-cli": "^1.8.3",
    "aws-cdk-lib": "^2.261.0",
    "constructs": "^10.6.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3"
  }
}
